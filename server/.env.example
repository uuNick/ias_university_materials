# База данных (укажи структуру без реального пароля)
DATABASE_URL="postgresql://username:password@localhost:5432/db_name?schema=public"
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=
DB_NAME=

# Настройки сервера
SERVER_PORT=5000
DOTENV_CONFIG_QUIET=true

# Настройка адреса клиента
DOMAIN=http://localhost:3000

# Секретный ключ для JWT-токенов
JWT_SECRET=

# Настройка парсер сервера
PARSER_SERVER_URL=http://localhost:8001

# Настройка сервера ИИ
AI_SERVER_URL=http://localhost:8002
